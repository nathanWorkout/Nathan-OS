   220 00000122 B402                        mov ah, 0x02
   221 00000124 B008                        mov al, 8
   222 00000126 B280                        mov dl, 0x80
   223 00000128 50                          push ax
   224 00000129 B80010                      mov ax, 0x1000
   225 0000012C 8EC0                        mov es, ax
   226 0000012E 58                          pop ax
   227 0000012F 31DB                        xor bx, bx
   228 00000131 CD13                        int 0x13
   229 00000133 7205                        jc disk_error
