     1                                  org 0x7E00
     2                                  bits 16
     3                                  
     4                                  ; En x86, il y a 2 façons de parler au matériel :
     5                                  ; 1 -> la mémoire RAM (mov)
     6                                  ; 2 -> les ports I/O : bus séparé de la RAM, 65536 ports numérotés de 0x0000 à 0xFFFF, chaque périphérique a ses propres ports
     7                                  ; On choisit le registre al car le port 0x92 est un port 8 bits (al = moitié basse de ax, 8 bits)
     8                                  ; Activation de la ligne A20 via le port 0x92 
     9                                  ; Sans A20 le bit 21 des adresses est bloqué à 0, impossible d'accéder au delà de 1Mo de mémoire
    10                                  
    11 00000000 E492                        in al, 0x92         ; Lit l'octet actuel du port 0x92 (System Control Port A)
    12 00000002 0C02                        or al, 0b00000010   ; Met le bit 1 à 1 pour activer A20
    13 00000004 24FE                        and al, 0b11111110  ; Met le bit 0 à 0 pour éviter le reset machine
    14 00000006 E692                        out 0x92, al        ; Renvoie l'octet modifié au port 0x92
    15                                  
    16                                      ; On teste si A20 est bien activé via un test mémoire
    17                                      ; Sans A20 : 0x100000 et 0x000000 pointent au même endroit physique (bit 21 ignoré)
    18                                      ; Avec A20 : 0x100000 et 0x000000 sont deux adresses séparées
    19                                      ; En mode réel on ne peut pas adresser 0x100000 directement, on utilise fs:0x0010 avec fs=0xFFFF
    20                                      ; (0xFFFF << 4) + 0x0010 = 0xFFFF0 + 0x10 = 0x100000
    21                                  
    22 00000008 31FF                        xor di, di                  ; di car c'est un segment et c'est le plus neutre des registres
    23 0000000A C60555                      mov byte [di], 0x55         ; Écrit 0x55 à l'adresse 0x0000 (ds=0 donc ds:di = 0x00000)
    24 0000000D B8FFFF                      mov ax, 0xFFFF
    25 00000010 8EE0                        mov fs, ax
    26 00000012 64A01000                    mov al, [fs:0x0010]         ; Lit ce qui est à 0x100000 via fs:0x0010
    27 00000016 3C55                        cmp al, 0x55                ; Si l'adresse est pareil -> A20 inactif, sinon -> A20 actif
    28 00000018 7509                        jne A20_OK                  ; A20 actif, on continue
    29                                  
    30 0000001A B80124                      mov ax, 0x2401      ; Fonction pour activer le port A20 via le BIOS 
    31 0000001D CD15                        int 0x15            ; Interruption pour activer A20 via le BIOS (alternative au port 0x92)
    32 0000001F 7302                        jnc A20_OK          ; Si pas d'erreur, A20 est activé, sinon échec (c'est la différence avec jne la)
    33                                  
    34                                  A20_FAIL:
    35 00000021 FA                          cli
    36 00000022 F4                          hlt
    37                                  
    38                                  A20_OK:
    39                                  ; A20 est maintenant activé, on peut accéder à toute la mémoire au-delà de 1Mo
    40                                  
    41                                  ; FAT_start = ReservedSector = 32
    42                                  
    43                                  ; (LBA c'est juste le numéro de secteur) = 1056
    44                                  ; cylindre = LBA / (secteurs_par_piste * têtes)
    45                                  ; tête     = (LBA / secteurs_par_piste) % têtes
    46                                  ; secteur  = (LBA % secteurs_par_piste) + 1
    47                                  
    48                                  ; valeurs du disque
    49                                  ; LBA = 1056                ; secteur du répertoire racine
    50                                  ; secteurs_par_piste = 63
    51                                  ; têtes = 255
    52                                  
    53                                  ; calcul secteurs par cylindre
    54                                  ; secteurs_par_cylindre = secteurs_par_piste * têtes
    55                                  ; secteurs_par_cylindre = 63 * 255
    56                                  ; secteurs_par_cylindre = 16065
    57                                  
    58                                  ; calcul cylindre
    59                                  ; cylindre = LBA / secteurs_par_cylindre
    60                                  ; cylindre = 1056 / 16065
    61                                  ; cylindre = 0
    62                                  
    63                                  ; calcul tête
    64                                  ; tête = (LBA / secteurs_par_piste) % têtes
    65                                  ; tête = (1056 / 63) % 255
    66                                  ; tête = 16 % 255
    67                                  ; tête = 16
    68                                  
    69                                  ; calcul secteur
    70                                  ; secteur = (LBA % secteurs_par_piste) + 1
    71                                  ; secteur = (1056 % 63) + 1
    72                                  ; secteur = 48 + 1
    73                                  ; secteur = 49
    74                                  
    75                                  ; résultat CHS final
    76                                  ; cylindre = 0
    77                                  ; tête = 16
    78                                  ; secteur = 49
    79                                  
    80 00000023 B402                        mov ah, 0x02        ; Fonction 0x02 : Lire des secteurs
    81 00000025 B001                        mov al, 1           ; Lire 1 secteur
    82 00000027 B500                        mov ch, 0           ; CH = cylindre 0 
    83 00000029 B131                        mov cl, 49          ; Secteur 49
    84 0000002B B610                        mov dh, 16          ; Tête 16
    85 0000002D B280                        mov dl, 0x80        ; Premier disque dur (0)
    86 0000002F B80009                      mov ax, 0x0900      
    87 00000032 8EC0                        mov es, ax          ; es:bx = adresse de destination pour le secteur lu (0x9000:0x0000 = 0x90000)
    88 00000034 31DB                        xor bx, bx          ; Offset à 0
    89 00000036 CD13                        int 0x13            ; Lit le secteur 49 du disque dur
    90                                  
    91 00000038 B80090                      mov ax, 0x9000
    92 0000003B 8ED8                        mov ds, ax
    93 0000003D BE0000                      mov si, 0x0000      ; [MODIF] opérande manquante — si pointe sur la première entrée du répertoire racine
    94                                  
    95                                  check_entry:            ; début de la boucle - APRES la lecture disque, on ne relit pas à chaque tour
    96 00000040 8A04                        mov al, [si]    
    97 00000042 3C00                        cmp al, 0x00        ; Vérifie que le premier octet du secteur n'est pas 0 (indique un secteur vide)
    98 00000044 742B                        je dir_end          ; fin du répertoire, le kernel n'existe pas sur le disque
    99 00000046 3CE5                        cmp al, 0xE5        ; Vérifie que le premier octet du secteur n'est pas 0xE5 (l'entrée est inutilisé)
   100 00000048 7422                        je next_entry
   101 0000004A 8A440B                      mov al, [si + 11]   ; offset 11 = octet d'attributs de l'entrée (pas 10 ; offset 10 = dernier octet du nom)
   102 0000004D 3C0F                        cmp al, 0x0F        ; 0x0F = attribut LFN (Long File Name), entrée à ignorer car pas au format 8.3
   103 0000004F 741B                        je next_entry
   104 00000051 BF[3C01]                    mov di, kernel_name ; Adresse du nom de fichier attendu
   105 00000054 8936[4701]                  mov [current_entry], si ; Sauvegarde le début de l'entrée actuelle pour pouvoir y revenir plus tard
   106 00000058 56                          push si             ; sauvegarde si sur la pile - read_name va l'incrémenter, il faut pouvoir revenir
   107 00000059 B90B00                      mov cx, 11          ; KERNEL  BIN
   108                                  
   109                                  read_name: 
   110 0000005C 8A04                        mov al, [si]        ; lire un octet du secteur
   111 0000005E 8A1D                        mov bl, [di]        ; lire un octet du nom attendu
   112 00000060 38D8                        cmp al, bl
   113 00000062 7507                        jne name_mismatch   ; les octets diffèrent : ce n'est pas le bon fichier
   114 00000064 46                          inc si              ; Passer à l'octet suivant du secteur
   115 00000065 47                          inc di              ; Passer à l'octet suivant du nom attendu
   116 00000066 E2F4                        loop read_name      ; Répéter pour les 11 octets du nom
   117 00000068 5E                          pop si              ; les 11 octets correspondent : on restaure si (current_entry suffit mais on dépile proprement)
   118 00000069 EB08                        jmp kernel_found    ; Si le nom correspond, on a trouvé le kernel
   119                                  
   120                                  name_mismatch:
   121 0000006B 5E                          pop si              ; restaure si avant de passer à l'entrée suivante (dépile ce qu'on a empilé avant read_name)
   122                                  
   123                                  next_entry: 
   124 0000006C 83C620                      add si, 32          ; 32 car chaque entrée de répertoire fait 32 octets, on passe à la prochaine entrée
   125 0000006F EBCF                        jmp check_entry     ; retour au début de la boucle - SURTOUT PAS read_cluster_loop qui remettrait si à 0x9000
   126                                  
   127                                  dir_end:                ; on a parcouru tout le répertoire sans trouver KERNEL  BIN
   128 00000071 FA                          cli
   129 00000072 F4                          hlt                 ; arrêt machine - le kernel est introuvable, rien à faire de plus
   130                                  
   131                                  kernel_found:
   132 00000073 8B36[4701]                  mov si, [current_entry] ; Revenir au début de l'entrée du kernel trouvée
   133 00000077 6631DB                      xor ebx, ebx
   134 0000007A 8B5C14                      mov bx, [si + 0x14]     ; cluster haut (16 bits)
   135 0000007D 66C1E310                    shl ebx, 16             ; décale vers le haut - Foutu spec de FAT que j'avais pas vu et qui m'a bloqué un peu mais j'ai trouvé ça
   136 00000081 8B5C1A                      mov bx, [si + 0x1A]     ; cluster bas (16 bits)
   137                                      ; ebx contient maintenant le numéro de cluster complet
   138                                      ; POV J'UTILISE ENFIN UN REGISTRE 32 BITS POUR LA PREMIERE FOIS WOOHOO
   139                                  
   140                                      ; NOTE: CHS hardcodé (63 secteurs/piste, 255 têtes) - fonctionne sur QEMU mais peut etre pas sur vrai hardware
   141                                      ; TODO: passer à LBA étendu (int 0x13 / 0x42) avant les tests hardware réels (phase 13)
   142                                  
   143 00000084 6689D8                      mov eax, ebx         ; Mettre le numéro de cluster ebx dans eax
   144 00000087 66C1E002                    shl eax, 2           ; Multiplie par 4 car chaque entrée FAT32 fait 4 octets
   145 0000008B 6631D2                      xor edx, edx         
   146 0000008E 66B900020000                mov ecx, 512         ; diviseur : 512 octets par secteur
   147 00000094 66F7F1                      div ecx              ; eax = secteur FAT, edx = offset dans ce secteur
   148 00000097 6683C020                    add eax, 32          ; On ajoute FAT_start à eax pour avoir le LBA réel
   149                                  
   150 0000009B 6652                        push edx             ; sauvegarde l'offset avant les divisions CHS qui vont écraser edx
   151                                  
   152                                      ; Conversion LBA -> CHS
   153                                      ; C = LBA / (heads * sectors_per_track)
   154                                      ; H = (LBA / sectors_per_track) % heads
   155                                      ; S = (LBA % sectors_per_track) + 1
   156                                  
   157 0000009D 66B93F000000                mov ecx, 63          ; sectors per track
   158 000000A3 6631D2                      xor edx, edx
   159 000000A6 66F7F1                      div ecx
   160                                  
   161 000000A9 88D3                        mov bl, dl            ; reste = secteur -1
   162 000000AB FEC3                        inc bl                ; secteur
   163                                  
   164 000000AD 66B9FF000000                mov ecx, 255
   165 000000B3 6631D2                      xor edx, edx
   166 000000B6 66F7F1                      div ecx               ; eax = cylindre, edx = head
   167                                  
   168 000000B9 88C5                        mov ch, al            ; cylindre
   169 000000BB 88D6                        mov dh, dl            ; tete
   170 000000BD 88D9                        mov cl, bl            ; secteur
   171                                  
   172                                      ; Lire le secteur FAT
   173 000000BF B402                        mov ah, 0x02
   174 000000C1 B001                        mov al, 1
   175 000000C3 B280                        mov dl, 0x80
   176 000000C5 50                          push ax               ; sauvegarder ah/al avant que mov ax,0x8000 les écrase (le bug qui ma pris du temp mdr)
   177 000000C6 B80080                      mov ax, 0x8000
   178 000000C9 8EC0                        mov es, ax            ; Buffer = 0x8000:0x0000 = 0x80000
   179 000000CB 58                          pop ax                ; [remettre ah=0x02, al=1
   180 000000CC 31DB                        xor bx, bx
   181 000000CE CD13                        int 0x13
   182 000000D0 7268                        jc disk_error
   183                                  
   184 000000D2 665E                        pop esi               ; Récupère l'offset sauvegardé avant les divisions CHS
   185                                  
   186                                  follow_chain:
   187 000000D4 2666678B06                  mov eax, [es:esi]       
   188                                      ; 0FFFFFFF car il garde les 28 bits et supprime les 4 bits hauts
   189                                      ; and pour masquer
   190 000000D9 6625FFFFFF0F                and eax, 0x0FFFFFFF     ; Lire 4 octets (entrée FAT car les 4 bits de haut sont réservés au FAT system)
   191 000000DF 663DF8FFFF0F                cmp eax, 0x0FFFFFF8
   192 000000E5 7305                        jae load_clusters       ; Si c'est le dernier cluster : on le charge
   193 000000E7 6689C3                      mov ebx, eax            ; sinon prochain cluster
   194 000000EA EB87                        jmp kernel_found        ; recalculer le CHS pour ce cluster et relire la FAT
   195                                  
   196                                  load_clusters:
   197                                      ; ebx = premier cluster du kernel
   198                                      ; LBA = 32 + 2*8 + (cluster - 2) * 8   (sectors_per_cluster = 8 sur QEMU par défaut)
   199                                      ; charger à 0x1000:0x0000 = 0x10000
   200 000000EC 6689D8                      mov eax, ebx
   201 000000EF 6683E802                    sub eax, 2
   202 000000F3 66B908000000                mov ecx, 8              ; sectors_per_cluster 
   203 000000F9 66F7E1                      mul ecx               
   204 000000FC 6683C030                    add eax, 48             ; data_start = reserved(32) + FATs(2*8) = 48
   205                                  
   206                                      ; Conversion LBA -> CHS avant int 0x13 
   207 00000100 66B93F000000                mov ecx, 63
   208 00000106 6631D2                      xor edx, edx
   209 00000109 66F7F1                      div ecx
   210 0000010C 88D3                        mov bl, dl
   211 0000010E FEC3                        inc bl
   212 00000110 66B9FF000000                mov ecx, 255
   213 00000116 6631D2                      xor edx, edx
   214 00000119 66F7F1                      div ecx
   215 0000011C 88C5                        mov ch, al
   216 0000011E 88D6                        mov dh, dl
   217 00000120 88D9                        mov cl, bl
